[program:sftpgo]
directory={{ app_base }}/sftpgo
command=/usr/bin/sftpgo --config-dir={{ app_base }}/sftpgo serve -l ""
user=azuracast
priority=700
numprocs=1
autostart=false
autorestart=true

stopasgroup=true
killasgroup=true

stdout_logfile={{ app_base }}/www_tmp/service_sftpgo.log
stdout_logfile_maxbytes=5MB
stdout_logfile_backups=5
redirect_stderr=true

stdout_events_enabled = true
stderr_events_enabled = true
