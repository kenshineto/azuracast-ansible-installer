[program:centrifugo]
directory={{ app_base }}/centrifugo
command=/usr/bin/centrifugo -c {{ app_base }}/centrifugo/config.toml
user=azuracast
priority=700
numprocs=1
autostart=false
autorestart=true

stopasgroup=true
killasgroup=true

stdout_logfile={{ app_base }}/www_tmp/service_centrifugo.log
stdout_logfile_maxbytes=5MB
stdout_logfile_backups=5
redirect_stderr=true

stdout_events_enabled = true
stderr_events_enabled = true
